<launch>
  <node pkg="turtlesim" type="turtlesim_node" name="turtlesim" output="screen"/>
  <node pkg="demo_cpp_service" type="turtle_control" name="turtle_controller" output="screen">
    <param name="k" value="1.0"/>
    <param name="max_speed" value="1.0"/>
  </node>
  <node pkg="demo_cpp_service" type="patrol_client" name="patrol_client" output="screen"/>
</launch>
