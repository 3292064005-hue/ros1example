<launch>
  <arg name="world" default="$(find fishbot_description)/world/custom_room.world" />
  <arg name="model" default="$(find fishbot_description)/urdf/fishbot/fishbot.urdf.xacro" />
  <param name="robot_description" command="$(find xacro)/xacro $(arg model)" />
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)" />
    <arg name="paused" value="false" />
    <arg name="use_sim_time" value="true" />
    <arg name="gui" value="true" />
    <arg name="headless" value="false" />
  </include>
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen" />
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_fishbot" args="-urdf -model fishbot -param robot_description" output="screen" />
</launch>
